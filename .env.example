# Copy this file to .env and fill in your own values
# Never commit .env — it is gitignored

# NeonDB — get from https://console.neon.tech
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Twilio — get from https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_VERIFY_SERVICE_SID=VAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_DEMO_PHONE=+919999999999

# Used to bypass OTP in dev/testing — set any 4-digit code
TWILIO_MASTER_OTP=1234

# Change this to a strong random string in your own deployment
JWT_SECRET=change-me-to-a-random-secret

PORT=3001
